# Copy to .env and adjust for local development. All values here are dev-only defaults.

# Database
DB_PASSWORD=iams_dev_password

# Object store (MinIO) - provisioned but unused until the attachments story ships
MINIO_ROOT_USER=iams-minio-bootstrap
MINIO_ROOT_PASSWORD=iams_dev_minio_password

# Backend auth (dev-mode stub - see IAMS_RTM_Report for why this is temporary)
