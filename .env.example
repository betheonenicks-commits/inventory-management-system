# Copy to .env and adjust. All values here are dev-only defaults - change every
# credential before a real deployment (see INSTALL.md).

# Database
DB_PASSWORD=iams_dev_password

# Host port overrides - only needed when a default collides with something
# already running on the host. Users only ever need IAMS_HTTP_PORT.
#IAMS_HTTP_PORT=80
#DB_HOST_PORT=5432
#MINIO_API_PORT=9000
#MINIO_CONSOLE_PORT=9001

# Object store (MinIO) - provisioned but unused until the attachments story ships
MINIO_ROOT_USER=iams-minio-bootstrap
MINIO_ROOT_PASSWORD=iams_dev_minio_password

# Backend auth (dev-mode stub - see IAMS_RTM_Report for why this is temporary)
IAMS_JWT_SECRET=dev-only-please-change-32-bytes-minimum-secret-value
IAMS_DEV_ADMIN_PASSWORD=admin123

# Email notifications (EPIC-NTF) - point at your SMTP relay for real delivery.
# Unreachable SMTP degrades gracefully: in-app notifications always deliver.
#IAMS_SMTP_HOST=localhost
#IAMS_SMTP_PORT=1025
#IAMS_MAIL_ENABLED=true
#IAMS_MAIL_FROM=iams@yourdomain.org
